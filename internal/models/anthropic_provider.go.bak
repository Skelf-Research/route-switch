package models

import (
	"context"
	"fmt"
	"strings"

	"github.com/anthropics/anthropic-sdk-go"
)

// AnthropicProvider implements the ModelProvider interface for Anthropic models
type AnthropicProvider struct {
	client     *anthropic.Client
	config     map[string]interface{}
	modelCache map[string]Model
}

// NewAnthropicProvider creates a new Anthropic provider instance
func NewAnthropicProvider() *AnthropicProvider {
	return &AnthropicProvider{
		modelCache: make(map[string]Model),
	}
}

// Name returns the name of the provider
func (p *AnthropicProvider) Name() string {
	return "Anthropic"
}

// Initialize sets up the provider with configuration
func (p *AnthropicProvider) Initialize(config map[string]interface{}) error {
	apiKey, ok := config["api_key"].(string)
	if !ok || apiKey == "" {
		return fmt.Errorf("Anthropic API key is required in configuration")
	}

	baseURL, ok := config["base_url"].(string)
	if !ok {
		baseURL = "" // Use default Anthropic endpoint
	}

	// Create Anthropic client options
	clientOptions := anthropic.DefaultClientOptions()
	clientOptions.APIKey = apiKey
	if baseURL != "" {
		clientOptions.BaseURL = baseURL
	}

	p.client = anthropic.NewClient(clientOptions)

	// Cache the known models with their properties
	p.modelCache = map[string]Model{
		"claude-3-opus-20240229": {
			Name:         "claude-3-opus-20240229",
			Provider:     "Anthropic",
			CostPerToken: 0.000015, // $0.015 per 1K tokens (input), $0.075 per 1K tokens (output)
			MaxTokens:    200000,
			Description:  "Anthropic's most powerful model",
		},
		"claude-3-sonnet-20240229": {
			Name:         "claude-3-sonnet-20240229",
			Provider:     "Anthropic",
			CostPerToken: 0.000003, // $0.003 per 1K tokens (input), $0.015 per 1K tokens (output)
			MaxTokens:    200000,
			Description:  "Balance of power and speed",
		},
		"claude-3-haiku-20240307": {
			Name:         "claude-3-haiku-20240307",
			Provider:     "Anthropic",
			CostPerToken: 0.00000025, // $0.00025 per 1K tokens (input), $0.00125 per 1K tokens (output)
			MaxTokens:    200000,
			Description:  "Anthropic's fastest model",
		},
		"claude-3-5-sonnet-20241022": {
			Name:         "claude-3-5-sonnet-20241022",
			Provider:     "Anthropic",
			CostPerToken: 0.000003, // $0.003 per 1K tokens (input), $0.015 per 1K tokens (output)
			MaxTokens:    200000,
			Description:  "Improved version of Claude Sonnet 3.5",
		},
	}

	return nil
}

// ListModels returns all available Anthropic models
func (p *AnthropicProvider) ListModels() ([]Model, error) {
	if p.client == nil {
		return nil, fmt.Errorf("Anthropic provider not initialized")
	}

	var models []Model
	for _, model := range p.modelCache {
		models = append(models, model)
	}

	return models, nil
}

// GetModel returns a specific model by name
func (p *AnthropicProvider) GetModel(name string) (Model, error) {
	model, exists := p.modelCache[name]
	if !exists {
		return Model{}, fmt.Errorf("model %s not found in Anthropic provider", name)
	}

	return model, nil
}

// CallModel calls the Anthropic API with the given prompt
func (p *AnthropicProvider) CallModel(modelName, prompt string) (string, error) {
	if p.client == nil {
		return "", fmt.Errorf("Anthropic provider not initialized")
	}

	model, err := p.GetModel(modelName)
	if err != nil {
		return "", err
	}

	// Create a message request to Anthropic
	resp, err := p.client.Messages.New(
		context.Background(),
		anthropic.MessageNewParams{
			Model:     anthropic.String(modelName),
			MaxTokens: anthropic.Int(int64(model.MaxTokens / 2)), // Use half the max tokens to be safe
			Messages: []anthropic.MessageParam{
				anthropic.NewUserMessage(
					anthropic.NewTextBlock(prompt),
				),
			},
		},
	)
	if err != nil {
		return "", fmt.Errorf("error calling Anthropic API: %w", err)
	}

	// Extract the response content
	var responseText strings.Builder
	for _, contentBlock := range resp.Content {
		if contentBlock, ok := contentBlock.AsTextBlock(); ok {
			responseText.WriteString(contentBlock.Text)
		}
	}

	return responseText.String(), nil
}

// EstimateCost estimates the cost of using a model for a given number of tokens
func (p *AnthropicProvider) EstimateCost(modelName string, inputTokens, outputTokens int) (float64, error) {
	model, err := p.GetModel(modelName)
	if err != nil {
		return 0, err
	}

	// For Claude models, input and output tokens have different costs
	// Using simplified calculation - in real implementation would use actual pricing
	// Opus: $0.015/1K input, $0.075/1K output
	// Sonnet: $0.003/1K input, $0.015/1K output
	// Haiku: $0.00025/1K input, $0.00125/1K output
	var inputCost, outputCost float64

	switch modelName {
	case "claude-3-opus-20240229":
		inputCost = float64(inputTokens) * 0.000015
		outputCost = float64(outputTokens) * 0.000075
	case "claude-3-sonnet-20240229":
		inputCost = float64(inputTokens) * 0.000003
		outputCost = float64(outputTokens) * 0.000015
	case "claude-3-haiku-20240307":
		inputCost = float64(inputTokens) * 0.00000025
		outputCost = float64(outputTokens) * 0.00000125
	default:
		// Default to model's cost per token if not specifically handled
		inputCost = float64(inputTokens) * model.CostPerToken
		outputCost = float64(outputTokens) * model.CostPerToken
	}

	return inputCost + outputCost, nil
}

// GetTokenCount returns an estimated token count for the given text
func (p *AnthropicProvider) GetTokenCount(text string) (int, error) {
	// A very rough approximation: divide character count by 4 to estimate tokens
	// For more accurate token counting, we would need to use a specific tokenizer
	// This is a simplification for demonstration purposes
	return len([]rune(text)) / 4, nil
}

// Close performs cleanup operations for the provider
func (p *AnthropicProvider) Close() error {
	// For Anthropic, we don't have persistent connections to close
	// but this method is included for interface compliance
	return nil
}